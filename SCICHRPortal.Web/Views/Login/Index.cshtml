@model SCICHRPortal.Web.Models.ViewModels.Login.LoginViewModel

@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Login";
    Layout = "LoginLayout";

}

<!DOCTYPE html>
<html>
<head>
    <link href="~/css/pages/login/login-page.css" rel="stylesheet" asp-append-version="true" />
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.7.2/css/all.css" />
    <link href="~/lib/toastr.js/toastr.min.css" rel="stylesheet" asp-append-version="true" />

</head>
<body>
    <input id="base-api-url" type="hidden" value="@Configuration["BaseApiUrl"]" />
    <div class="row log-in-main-container">
        <div class="col-8 col-md-8 logo-container">
            <div class="align-container-1">
                <div class="d-flex flex-row justify-content-center align-items-center w-100">
                    <div id="logo">
                        <img id="lmsi-main-logo" src="/images/logo.png">
                    </div>
                </div>
                <div class="d-flex flex-row justify-content-center align-items-center w-100">
                    <div id="logo">
                        <img id="lmsi-logo" src="/images/LMSI-text 1.png">
                    </div>
                </div>
                <span class="enrollment-tool-word-style">SCIC HR Portal</span>
            </div>

        </div>
        <div class="col-4 col-md-4 log-in-container">
            <div class="d-flex justify-content-left">
                <div class="container align-container-2">
                    <div class="row h-100 justify-content-center log-in-form" id="login-form-container">
                        <form class="col-12 row" autocomplete="on" id="log-in-form">
                    <div class="text-center m-3">
                        <img id="" src="/images/create account icon.png">
                    </div>
                    <h2 class="user-login-text form-group text-center">SIGN IN</h2>
                    <div class="form-group mx-auto">
                        <input asp-for="IsLogin" hidden />
                        <input type="text" asp-for="Email" class="form-control username-field lowercase" id="user-name" placeholder="Email">
                        <span asp-validation-for="Email" class="text-danger ml-5"></span>

                    </div>
                    <div class="form-group mt-4 pt-4 mx-auto">
                        <input type="password" asp-for="Password" class="form-control password-field lowercase" id="password" placeholder="Password">
                        <i class="fas fa-eye fa-2x text-white float-right show-pass" id="show-login-pass"></i>
                        <span asp-validation-for="Password" class="text-danger ml-5"></span>
                    </div>
                    <div class="">
                        <a asp-area="" asp-controller="User" asp-action="SendEmail" class="forgot-password-link">
                            <span class="">forgot password?</span>
                        </a>
                    </div>


                    <div class="form-group mt-4 pt-4 " align="center">
                        <button type="submit" class="btn btn-light log-in-btn" id="log-in-btn">LOGIN</button>
                    </div>
                    <hr class="solid">
                    <label class="d-block text-center">no account yet? <span class="sign-up-span">sign up here</span></label>
                </form>
                    </div>
                    <div class="row h-100 justify-content-center log-in-form d-none" id="register-form-container">
                        <form class="col-12 row my-auto" id="register-form">
                            <div class="text-center col-12">
                                <img id="" src="/images/create account icon.png">
                            </div>
                            <div class="form-group col-md-6">
                                <input type="text" asp-for="Email" class="form-control lowercase" placeholder="Email Address">
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="form-group col-md-6">
                                <select class="form-control user-role" id="add-user-role" disabled></select>
                                <span class="text-danger user-role-validation d-none mt-2">Select Role</span>
                            </div>
                            <div class="form-group col-md-6">
                                <input type="text" asp-for="LastName" class="form-control" placeholder="Last Name">
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                            <div class="form-group col-md-6">
                                <input type="text" asp-for="MiddleName" class="form-control" placeholder="Middle Name">
                                <span asp-validation-for="MiddleName" class="text-danger"></span>
                            </div>
                            <div class="form-group col-md-6">
                                <input type="text" asp-for="FirstName" class="form-control" placeholder="First Name">
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>

                            <div class="form-group col-md-6">
                                <input type="text" asp-for="ContactNumber" class="form-control" placeholder="Contact Number">
                                <span asp-validation-for="ContactNumber" class="text-danger"></span>
                            </div>
                            @*     <div class="form-group col-md-6">
                            <input type="password" asp-for="Password" class="form-control" id="new-password" placeholder="New Password">
                            <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                            <div class="form-group col-md-6">
                            <input type="password" asp-for="ConfirmPassword" class="form-control" id="confirm-password" placeholder="Confirm Password">
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>
                            <span class="d-none text-warning unmatched-password-validation">New Password and Confirm Password does not matched.</span>*@

                            <div class="form-group col-md-12" align="center">
                                <button type="submit" class="btn btn-light log-in-btn" id="">Create Account</button>
                            </div>
                            <hr class="solid">
                            <label class="d-block text-center">already have an account? <span class="sign-in-span">sign in here</span></label>
                        </form>
                    </div>
                    <div class="row h-100 justify-content-center log-in-form d-none" id="success-register-container">
                        <div class="text-center col-12 my-auto">
                            <img id="login-logo" src="/images/check your email icon.png">
                            <label class="d-block text-center">Your account has been register</label>
                            <button type="button" class="btn btn-light log-in-btn" id="procced-login">procced to login</button>
                        </div>

                    </div>
                </div>

            </div>

        </div>
    </div>

</body>
</html>



<div id="busy-indicator-container" class="d-none">
    <img class="indicator-img-position " src="/images/loading-indicator.gif">
</div>

@section Scripts {
    @{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
<script src="~/lib/toastr.js/toastr.min.js"></script>
<script src="~/js/helpers/api-helper.js"></script>
<script src="~/js/helpers/form-helper.js"></script>
<script src="~/js/helpers/cookie-helper.js"></script>
<script src="~/js/helpers/date-helper.js"></script>
<script src="~/js/helpers/string-helper.js"></script>
<script src="~/js/pages/login/login-page.js"></script>
}


